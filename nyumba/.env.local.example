# ── Supabase ─────────────────────────────────────────────────────
# Pata kutoka: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App URL ───────────────────────────────────────────────────────
# URL kamili ya app yako (Vercel au domain yako)
NEXT_PUBLIC_APP_URL=https://nyumbafasta.co

# ── Cron Job Security ─────────────────────────────────────────────
# Token ya siri — tengeneza kwa: openssl rand -hex 32
CRON_SECRET=your-secret-token-here

# ── Lead Agent ────────────────────────────────────────────────────
# Webhook secret — tengeneza yoyote ya siri
WEBHOOK_SECRET=nyumbafasta-webhook-2026-secret

# ── Cloudinary ────────────────────────────────────────────────────
# Pata kutoka: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=nyumba_listings
NEXT_PUBLIC_CLOUDINARY_PROFILE_PRESET=nyumba_profiles

# ── Push Notifications (VAPID) ────────────────────────────────────
# Tengeneza kwa: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BExamplePublicKeyHere...
VAPID_PRIVATE_KEY=ExamplePrivateKeyHere...
VAPID_EMAIL=mailto:admin@nyumbafasta.co

# ── AzamPay Payment Gateway ───────────────────────────────────────
# Pata kutoka: https://developerdocs.azampay.co.tz
# Kama AZAMPAY_CLIENT_ID haijawekwa, app itatumia DEV mode (malipo ya bandia)
AZAMPAY_APP_NAME=NyumbaFasta
AZAMPAY_CLIENT_ID=your-azampay-client-id
AZAMPAY_CLIENT_SECRET=your-azampay-client-secret
AZAMPAY_API_KEY=your-azampay-api-key
AZAMPAY_ENVIRONMENT=sandbox

# ── Support WhatsApp ──────────────────────────────────────────────
# Namba ya WhatsApp ya support (format: 255XXXXXXXXX bila +)
NEXT_PUBLIC_SUPPORT_WHATSAPP=255665831694

# ── Anthropic (Amina AI) ──────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Meta / Facebook / Instagram ───────────────────────────────────
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_ACCESS_TOKEN=your-facebook-user-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
# Facebook Commerce Catalog — pata kutoka Meta Commerce Manager
FACEBOOK_CATALOG_ID=your-catalog-id
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_USER_ID=your-instagram-user-id
META_WEBHOOK_VERIFY_TOKEN=your-meta-webhook-verify-token

# ── WhatsApp Business API ─────────────────────────────────────────
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ── Resend (email) ────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key

# ── Google Maps ───────────────────────────────────────────────────
# Maps JavaScript API (client-side) — restrict to HTTP referrers:
#   localhost:3000, nyumbafasta.co, *.vercel.app
# Enable: Maps JavaScript API, Places API (Autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-js-api-key

# Google Places + Geocoding + Distance Matrix (server-side only)
# Restrict by IP (Vercel server IPs). Do NOT prefix with NEXT_PUBLIC_.
# Enable: Places API, Geocoding API, Distance Matrix API
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@nyumbafasta.co
ADMIN_WHATSAPP_NUMBER=255XXXXXXXXX
